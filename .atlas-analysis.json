  "keyFeatures": [
    "Role-based access control (Admin / User)",
    "Trip creation and management with cost and distance tracking",
    "Collaborator management with branch-office assignments and distance records",
    "Branch office (sucursales) CRUD management",
    "Carrier (transportista) management with rate information",
    "Travel reports with joined data across users, branches, and carriers",
    "Session-based authentication using express-session",
    "MySQL database via Sequelize ORM"
